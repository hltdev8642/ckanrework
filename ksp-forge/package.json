{
  "name": "ksp-forge",
  "version": "0.5.8",
  "description": "KSP mod manager built with Electron + React",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never"
  },
  "keywords": [
    "ksp",
    "mods",
    "electron"
  ],
  "homepage": "https://github.com/JLSkyzer/ckanrework",
  "repository": {
    "type": "git",
    "url": "https://github.com/JLSkyzer/ckanrework.git"
  },
  "author": {
    "name": "JLSkyzer",
    "email": "jlskyzer@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@types/semver": "^7.5.8",
    "@types/unzip-stream": "^0.3.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^11.9.1",
    "dompurify": "^3.2.5",
    "marked": "^15.0.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "semver": "^7.7.1",
    "simple-git": "^3.27.0",
    "unzip-stream": "^0.3.4",
    "zustand": "^5.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
